DATABASE_URL=mysql+asyncmy://assetlog:assetlog@localhost:3306/assetlog
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=["http://localhost:3000"]
COOKIE_SECURE=false
COOKIE_SAMESITE=strict
REFRESH_INTERVAL_MINUTES=60
TZ=Asia/Seoul

# Single-owner password authentication (bcrypt hash — never store plain text)
# Generate: python -c 'import bcrypt; print(bcrypt.hashpw(b"your-password", bcrypt.gensalt(rounds=12)).decode())'
APP_PASSWORD_HASH=
# Rate limiting — per-IP (optional)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=600
# Rate limiting — global (optional)
LOGIN_GLOBAL_MAX_ATTEMPTS=50
LOGIN_GLOBAL_WINDOW_SECONDS=60
# Login attempt audit log retention (days)
LOGIN_ATTEMPT_RETENTION_DAYS=90
